{
  "name": "e-arsip-desa",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "server": "node e-arsip-desa/server.js",
    "server:dev": "nodemon e-arsip-desa/server.js",
    "start": "concurrently \"npm run server:dev\" \"npm run dev\"",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "cd e-arsip-desa && npx jest --config jest.config.js --forceExit --detectOpenHandles",
    "test:frontend": "npx vitest run --config vitest.config.ts",
    "test:backend:watch": "cd e-arsip-desa && npx jest --config jest.config.js --watch",
    "test:frontend:watch": "npx vitest --config vitest.config.ts"
  },
